# Mode: "hosted" (Vercel, read-only) or "local" (full features, default)
NEXT_PUBLIC_MODE=local

# Path to the InsightXpert repo (local mode only — needed for Python CLI, SQLite DBs, prompts)
INSIGHTXPERT_REPO=../InsightXpert

# Override individual paths if needed (all default to deriving from INSIGHTXPERT_REPO):
# RESULTS_DIR=
# VENV_PYTHON=
# DB_ROOT=
# PROMPTS_DIR=

# Cloudflare R2 (hosted mode — results storage)
# R2_ACCOUNT_ID=<cloudflare account id>
# R2_API_TOKEN=<cloudflare API token with R2 read access>
# R2_PUBLIC_DOMAIN=pub-<bucket_id>.r2.dev
# R2_BUCKET=insightxpert-results

# Turso (hosted mode — SQL execution against benchmark databases)
# TURSO_ORG=<your-turso-org>  (e.g. nachiketkandari)
# TURSO_REGION=aws-ap-south-1
# TURSO_AUTH_TOKEN=<group auth token>
